{
  "type": "object",
  "required": ["infra"],
  "properties": {
    "infra": {
      "type": "object",
      "oneOf": [
        {
          "required": ["aws"],
          "properties": {
            "aws": {
              "type": "object",
              "required": ["ssh_key"],
              "properties": {
                "ec2_instance_type": {
                  "type": "string",
                  "description": "EC2 instance type for the frontend host",
                  "default": "t3.large"
                },
                "volume_size": {
                  "type": "integer",
                  "description": "EBS root volume size for the frontend EC2 instance (GiB)",
                  "default": 125
                },
                "region": {
                  "type": "string",
                  "description": "AWS region used for the deployment",
                  "default": "eu-central-1"
                },
                "ssh_key": {
                  "type": "string",
                  "description": "Name of the SSH key in AWS used to connect to the EC2 instance"
                },
                "ssh_key_path": {
                  "type": "string",
                  "description": "Private key path on the opsforge runner",
                  "default": "~/.ssh/id_rsa"
                }
              }
            }
          }
        },
        {
          "required": ["hosts"],
          "properties": {
            "hosts": {
              "type": "object",
              "required": ["frontend"],
              "properties": {
                "frontend": {
                  "type": "string",
                  "description": "Hostname/IP of the control plane host (OpenNebula + COGNIT Frontend)"
                }
              }
            }
          }
        }
      ]
    },
    "cognit": {
      "type": "object",
      "required": ["one_pass"],
      "properties": {
        "one_pass": {
          "type": "string",
          "description": "oneadmin password for the Cloud-Edge Manager (required for deploy)"
        },
        "one_version": {
          "type": "string",
          "description": "OpenNebula version to deploy",
          "default": "7.1"
        },
        "flavour": {
          "type": "string",
          "description": "Use case flavour for edge cluster (NatureFR, SmartCity, EnergyTorch, Energy, CyberSecurity); required for deploy-edge"
        },
        "provider": {
          "type": "string",
          "description": "Provider name for cluster metadata; required for deploy-edge"
        },
        "geolocation": {
          "type": "string",
          "description": "Cluster geolocation (lat,lon) for discovery",
          "default": "48.8566,2.3522"
        },
        "edge_host_ips": {
          "type": "array",
          "items": { "type": "string" },
          "description": "IP addresses of pre-existing edge hosts to add as KVM compute nodes; required for deploy-edge"
        }
      }
    }
  }
}
