#
# Checks if all of the opsforge dep`en`dencies are met
# Will raise an error if a dependency is missing
#
def verify_requirements(require_terraform: true)
    ['ansible'].each do |cmd|
        raise "Missing required command #{cmd}. Check requirements on documentation." unless cmd_exists?(cmd)
    end
    raise "Missing required command terraform. Check requirements on documentation." if require_terraform && !cmd_exists?('terraform')
    raise "Missing required command aws. Check requirements on documentation." if require_terraform && !cmd_exists?('aws')

    raise '"one-deploy" git submodule is missing' unless File.directory?("#{__dir__}/ansible/one-deploy")

    ['json-schema'].each do |gem|
        begin
            Gem::Specification.find_by_name(gem)
        rescue StandardError
            raise "Missing gem \"#{gem}\""
        end
    end
end

#
# Check if the provided opsforge template complies with the schema
#
# @param [Hash] opsforge_template opsforge yaml template contents
#
def deep_stringify_keys(obj)
    case obj
    when Hash then obj.each_with_object({}) {|(k, v), o| o[k.to_s] = deep_stringify_keys(v) }
    when Array then obj.map {|e| deep_stringify_keys(e) }
    else obj
    end
end

def validate_template(opsforge_template)
    schema = JSON.load_file("#{__dir__}/schema.json")
    data = deep_stringify_keys(opsforge_template)

    begin
        JSON::Validator.validate!(schema, data)
    rescue JSON::Schema::ValidationError => e
        STDERR.puts e.message
        exit 1
    end
end

#
# Provisions the COGNIT modules in AWS using terraform
#
# @param [Hash] opsforge_template opsforge yaml template contents
#
# @return [Hash] Infrastructure hostnames for each COGNIT module
#
def terraform_aws(opsforge_template)
    puts 'Setting up infrastructure on AWS'

    tfvars = "#{__dir__}/terraform/aws/terraform.tfvars"
    File.new(tfvars, 'w') unless File.exist?(tfvars)

    tfvars_content = "local_machine_ip = \"#{public_ip}\"\n"
    opsforge_template[:infra][:aws].each {|k, v| tfvars_content << "#{k} = \"#{v}\"\n" }

    File.open(tfvars, 'w') {|file| file.puts(tfvars_content) }

    output = JSON.parse(terraform('aws').last)
    frontend_dns = output['frontend']['value']['public_dns']

    puts 'Infrastructure on AWS has been deployed'
    { frontend: frontend_dns }
end

#
# Sets up the COGNIT control plane with ansible using one-deploy + PoC playbooks
#
# @param [Hash] infra Must include :frontend (hostname/IP of the control plane host)
# @param [Hash] opsforge_template opsforge yaml template contents
# @param [Boolean] edge_only if true, run only edge-cluster playbook
#
def ansible(infra, opsforge_template, edge_only: false)
    puts edge_only ? 'Provisioning edge cluster' : 'Installing OpenNebula and COGNIT'

    Dir.chdir("#{__dir__}/ansible/one-deploy")
    begin
      cmd_exec('make requirements')
    rescue StandardError
      # Fallback when Poetry is not available: install galaxy collections only
      cmd_exec('ansible-galaxy collection install -p ansible_collections -r requirements.yml')
    end

    cognit = opsforge_template[:cognit] || {}
    ansible_user = opsforge_template[:infra].key?(:aws) ? 'ubuntu' : 'root'

    inventory = {
        'all' => {
            'vars' => {
                'ansible_user' => ansible_user,
                'ansible_ssh_extra_args' => '-o ForwardAgent=yes',
                'update_pkg_cache' => true,
                'ensure_hostname' => true,
                'ensure_hosts' => true,
                'one_version' => (cognit[:one_version] || '7.1').to_s,
                'repos_enabled' => %w[ceph frr grafana],
                'one_pass' => cognit[:one_pass],
                'db_backend' => 'SQLite',
                'features' => { 'provision' => true },
                '_pip_extra_args' => '--break-system-packages',
                'ds' => { 'mode' => 'ssh' }
            }
        },
        'frontend' => {
            'hosts' => {
                'f1' => { 'ansible_host' => infra[:frontend].to_s }
            }
        },
        'node' => { 'hosts' => {} }
    }

    if cognit[:one_internal_repo_url]
        inventory['all']['vars']['one_internal_repo_url'] = cognit[:one_internal_repo_url].to_s
        inventory['all']['vars']['one_internal_repo_component'] = (cognit[:one_internal_repo_component] || 'poc-cognit').to_s
    end

    if cognit[:edge_host_ips] && cognit[:edge_host_ips].length > 0
        inventory['all']['vars']['edge_host_ips'] = cognit[:edge_host_ips].map(&:to_s)
        inventory['all']['vars']['flavour'] = cognit[:flavour].to_s if cognit[:flavour]
        inventory['all']['vars']['provider'] = cognit[:provider].to_s if cognit[:provider]
        inventory['all']['vars']['geolocation'] = (cognit[:geolocation] || '48.8566,2.3522').to_s
    end

    cfg = <<~EOT
        [defaults]
        collections_path=./one-deploy/ansible_collections/
        inventory=./inventory.yaml
        gathering=explicit
        host_key_checking=false
        display_skipped_hosts=true
        retry_files_enabled=false
        any_errors_fatal=true
        stdout_callback=default
        result_format=yaml
        timeout=30
        remote_user=#{ansible_user}
        [privilege_escalation]
        become=true
        become_user=root
        [ssh_connection]
        pipelining=true
        ssh_args=#{ANSIBLE_SSH_ARGS_COMMON}
    EOT

    Dir.chdir("#{__dir__}/ansible")
    File.write("#{__dir__}/ansible/inventory.yaml", inventory.to_yaml)
    File.write("#{__dir__}/ansible/ansible.cfg", cfg)

    collections = 'ansible.posix community.docker'
    cmd_exec("ansible-galaxy collection install #{collections}")

    unless edge_only
        30.times do |t|
            raise 'Timeout while waiting for SSH access to frontend' if t == 29
            begin
                cmd_exec("ssh #{ansible_user}@#{infra[:frontend]} uptime", false)
            rescue StandardError
                sleep 1
                next
            end
            break
        end
    end

    if edge_only
        cmd_exec('ansible-playbook playbooks/edge-only.yaml')
    else
        cmd_exec('ansible-playbook playbooks/cognit.yaml')
    end
    Dir.chdir("#{__dir__}/..")

    puts edge_only ? 'Edge cluster provisioned' : 'OpenNebula and COGNIT installed'
end

#
# Triggers the build of the Serverless Runtime Appliance
# The host should be an OpenSUSE host
#
# @param [String] host IP/Hostname of the host where the build will occurr
# @param [String] sr_version Serverless Runtime version to install in the App
# @param [String] jumphost IP/Hostname of the host used as SSH proxy
#
def kiwi(host, sr_version = nil, jumphost = nil, flavour = 'serverless_runtime')
    inventory = {
        'kiwi' => {
            'hosts' => {
                'kiwi1' => {
                    'ansible_host' => host,
                    'ansible_user' => 'root'
                }
            }
        }
    }

    if jumphost && !jumphost.empty?
        inventory['kiwi']['hosts']['kiwi1']['ansible_ssh_common_args'] =
            "-o ProxyJump=root@#{jumphost}"
    end

    if sr_version && !jumphost.empty?
        inventory['kiwi']['hosts']['kiwi1']['sr_version'] = sr_version
    end

    if flavour && !flavour.empty?
        inventory['kiwi']['hosts']['kiwi1']['flavour'] = flavour
    end

    Dir.chdir("#{__dir__}/ansible")
    File.write("#{__dir__}/ansible/inventory_kiwi.yaml", inventory.to_yaml)
    cmd_exec('ansible-playbook playbooks/kiwi.yaml -i inventory_kiwi.yaml')
    Dir.chdir("#{__dir__}/..")

    puts "The appliance was generated at #{host}:/root/kiwi-image/output/cognit-sr.x86_64-1.0.0.qcow2"
end

#
# Populates the Cloud-Edge manager with the Serverless Runtimes appliances
#
# @param [String] frontend Cloud-Edge manager hostname
# @param [Hash] opsforge_template opsforge yaml template contents
#
def terraform_opennebula(frontend, opsforge_template)
    puts 'Setting up Cloud-Edge Manager for Cognit'

    tfvars = "#{__dir__}/terraform/opennebula/terraform.tfvars"
    File.new(tfvars, 'w') unless File.exist?(tfvars)

    tfvars_content = ''

    oned = "http://#{frontend}:2633/RPC2"
    oneflow = "http://#{frontend}:2474"

    tfvars_content << "oned = \"#{oned}\"\n"
    tfvars_content << "oneflow = \"#{oneflow}\"\n"
    tfvars_content << "password = \"#{opsforge_template[:cognit][:cloud][:password]}\"\n"

    if opsforge_template[:cognit].key?(:apps)
        opsforge_template[:cognit][:apps].each do |app, path|
            tfvars_content << "image_#{app} = \"#{path}\""
        end
    end

    File.open(tfvars, 'w') {|file| file.puts(tfvars_content) }

    terraform('opennebula')

    puts 'Frontend ready for Cognit'
end

#
# Deletes COGNIT infrastructure provisioning and
# any previously generated output file
#
def clean
    puts 'Destroying infrastructure'

    # Destroy infrastructure in AWS
    Dir.chdir("#{__dir__}/terraform/aws")
    ['init', 'destroy --auto-approve'].each do |cmd|
        cmd_exec("terraform #{cmd}", false)
    end

    deployment_output = {
        '/terraform/opennebula/terraform.' => ['tfstate', 'tfstate.backup', 'tfvars'],
        '/ansible/' => ['ansible.cfg', 'inventory.yaml'],
        '/opsforge' => ['.log']
    }

    deployment_output.each do |k, v|
        v.each do |f|
            file = "#{__dir__}#{k}#{f}"
            File.delete(file) if File.exist?(file)
        end
    end

    puts 'COGNIT deployment succesfully destroyed'
end

# Helpers

#
# Checks if a port is active on a host
#
# @param [String] host
# @param [Integer] port
#
# @return [Boolean]
#
def socket?(host, port)
    begin
        Timeout.timeout(5) do
            begin
                socket = TCPSocket.new(host, port)
                socket.close
                true
            rescue Errno::ECONNREFUSED, Errno::EHOSTUNREACH
                false
            end
        end
    rescue Timeout::Error
        false
    end
end

#
# Executes a command on the CLI
#
# @param [String] cmd Command
# @param [Boolean] log Log command output in opsforge.log
#
# @return [String] Command standard output
#
def cmd_exec(cmd, log = true)
    output = []

    Open3.popen3(cmd) do |_stdin, stdout, stderr, wait_thr|
        stdout_thread = Thread.new do
            while (line = stdout.gets)
                output << line
                puts line
                log(line) if log
            end
        end

        stderr_thread = Thread.new do
            while (line = stderr.gets)
                STDERR.puts line if log
                log(line) if log
            end
        end

        stdout_thread.join
        stderr_thread.join

        exit_status = wait_thr.value
        if exit_status != 0
            STDERR.puts "Command \"#{cmd}\" failed:" if log
            raise "#{stdout}\n#{stderr}"
        end
    end

    output.join("\n")
end

#
# Checks if a command exist
#
# @param [String] command Command
#
# @return [Boolean]
#
def cmd_exists?(command)
    exts = ENV['PATHEXT'] ? ENV['PATHEXT'].split(';') : ['']
    ENV['PATH'].split(File::PATH_SEPARATOR).each do |path|
        exts.each do |ext|
            exe = File.join(path, "#{command}#{ext}")
            return true if File.executable?(exe) && !File.directory?(exe)
        end
    end
    false
end

#
# Provisions infrastructure using terraform
#
# @param [String] provider
#
# @return [String] terraform output after provisioning completes
#
def terraform(provider)
    output = []

    Dir.chdir("#{__dir__}/terraform/#{provider}")

    ['terraform init', 'terraform apply --auto-approve', 'terraform output -json'].each do |cmd|
        output << cmd_exec(cmd)
    end

    Dir.chdir(__dir__)

    output
end

#
# Gather the public_ip that the opsforge executor uses to reach the internet
#
# @return [String] public IP address
#
def public_ip
    uri = URI('https://api.ipify.org')
    response = Net::HTTP.get(uri)
    response.strip
end

#
# Writes information to the dedicated opsforge log file
#
# @param [String] info information to be logged
#
def log(info)
    file = "#{__dir__}/opsforge.log"
    File.open(file, 'a') do |f|
        f.puts info
    end
end

#
# Measures how long will a block of code take to run
#
# @param [Proc] &logic Lines of code to be executed
#
# @return [String] Command standard output
#
def howlong(&logic)
    start_time = Time.now
    output = logic.call
    puts "Took #{Time.now - start_time} seconds"
    output
end

# BEGIN

case ARGV[0]
when 'deploy'
    raise 'Usage: ./opsforge deploy <template.yaml>' if ARGV[1].to_s.empty?
    opsforge_template = YAML.load_file(ARGV[1])
    opsforge_template = opsforge_template.transform_keys(&:to_sym)
    opsforge_template[:infra] = (opsforge_template[:infra] || {}).transform_keys(&:to_sym)
    opsforge_template[:infra][:hosts] = (opsforge_template[:infra][:hosts] || {}).transform_keys(&:to_sym) if opsforge_template[:infra][:hosts]
    opsforge_template[:infra][:aws] = (opsforge_template[:infra][:aws] || {}).transform_keys(&:to_sym) if opsforge_template[:infra][:aws]
    opsforge_template[:cognit] = (opsforge_template[:cognit] || {}).transform_keys(&:to_sym)
    opsforge_template[:cognit].each_key {|k| opsforge_template[:cognit][k] = opsforge_template[:cognit][k].transform_keys(&:to_sym) if opsforge_template[:cognit][k].is_a?(Hash) }

    validate_template(opsforge_template)
    raise 'Template must include :cognit: :one_pass:' unless opsforge_template[:cognit] && opsforge_template[:cognit][:one_pass]

    verify_requirements(require_terraform: opsforge_template[:infra].key?(:aws))

    if opsforge_template[:infra].key?(:aws)
        howlong { infra = terraform_aws(opsforge_template) }
        ssh_connection = "- SSH: Connect to the frontend \"#{infra[:frontend]}\" with the \"ubuntu\" user and the SSH key specified in the template."
    else
        raise 'Template must include :infra: :hosts: :frontend:' unless opsforge_template[:infra][:hosts] && opsforge_template[:infra][:hosts][:frontend]
        infra = { frontend: opsforge_template[:infra][:hosts][:frontend] }
        ssh_connection = "- SSH: Connect to the frontend \"#{infra[:frontend]}\" as root (or the configured user)."
    end

    howlong { ansible(infra, opsforge_template) }

    report = <<~EOT
        #{'='*80}

        Infrastructure
        #{JSON.pretty_generate(infra)}

        Access
        - Cloud-Edge Manager: oneadmin / (password from template :cognit: :one_pass:)
        - Sunstone:    http://#{infra[:frontend]}:9869
        - FireEdge:    http://#{infra[:frontend]}:2616
        - COGNIT Frontend: http://#{infra[:frontend]}:1338
        #{ssh_connection}

        Logs available at ./opsforge.log
    EOT

    puts report
when 'deploy-edge'
    verify_requirements(require_terraform: false)
    raise 'Usage: ./opsforge deploy-edge <edge_template.yaml>' if ARGV[1].to_s.empty?
    opsforge_template = YAML.load_file(ARGV[1])
    opsforge_template = opsforge_template.transform_keys(&:to_sym)
    opsforge_template[:infra] = (opsforge_template[:infra] || {}).transform_keys(&:to_sym)
    opsforge_template[:infra][:hosts] = (opsforge_template[:infra][:hosts] || {}).transform_keys(&:to_sym) if opsforge_template[:infra][:hosts]
    opsforge_template[:cognit] = (opsforge_template[:cognit] || {}).transform_keys(&:to_sym)
    opsforge_template[:cognit].each_key {|k| opsforge_template[:cognit][k] = opsforge_template[:cognit][k].transform_keys(&:to_sym) if opsforge_template[:cognit][k].is_a?(Hash) }

    validate_template(opsforge_template)
    raise 'Edge template must include :infra: :hosts: :frontend:' unless opsforge_template[:infra][:hosts] && opsforge_template[:infra][:hosts][:frontend]
    raise 'Edge template must include :cognit: :one_pass:, :edge_host_ips:, :flavour:, :provider:' unless opsforge_template[:cognit] && opsforge_template[:cognit][:one_pass] && opsforge_template[:cognit][:edge_host_ips] && opsforge_template[:cognit][:edge_host_ips].length > 0 && opsforge_template[:cognit][:flavour] && opsforge_template[:cognit][:provider]

    infra = { frontend: opsforge_template[:infra][:hosts][:frontend] }
    howlong { ansible(infra, opsforge_template, edge_only: true) }
    puts "Edge cluster (#{opsforge_template[:cognit][:flavour]}) provisioned. Frontend: #{infra[:frontend]}"
when 'clean'
    verify_requirements(require_terraform: true)
    clean
when 'build_sr'
    verify_requirements(require_terraform: false)
    ansible_host = ARGV[1]

    if ansible_host.nil?
        STDERR.puts HELP
        exit 1
    end

    args = [ansible_host]

    kiwi(*args) unless ARGV[2]

    ARGV[2..-1].each do |arg|
        args << arg unless arg.nil?
    end

    kiwi(*args)
when 'help'
    puts HELP
else
    STDERR.puts HELP
    exit 1
end
